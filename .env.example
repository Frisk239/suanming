# .env.example
# 复制为 .env.local 并填入真实值（.env.local 不入库）。
# 从 Supabase Dashboard → Project Settings → API 获取。

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 可选：本机翻墙连 Supabase 时设代理；生产环境（Vercel）留空直连
# HTTPS_PROXY=http://127.0.0.1:7890

# DeepSeek API（③层 LLM，M3 用）— 从 platform.deepseek.com 获取
DEEPSEEK_API_KEY=
# 模型：deepseek-v4-flash（默认）或 deepseek-v4-pro（旧 deepseek-chat 2026/7/24 弃用）
DEEPSEEK_MODEL=deepseek-v4-flash
# LLM 切换：deepseek | glm（默认 deepseek）
LLM_PROVIDER=deepseek

# BGE-M3 embedding 微服务（Python FastAPI，本地常驻）
# 启动：conda activate sk-learn && python scripts/embed-server.py
EMBED_URL=http://127.0.0.1:8765
# 防止 undici 全局代理拦截 localhost 调用（embedding 微服务走本地）
NO_PROXY=localhost,127.0.0.1
