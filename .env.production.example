# .env.production.example
# 复制为 .env.production（不入库），填真实值，scp 到服务器 /opt/suanming/
# 由 docker-compose 的 env_file 注入 next-app 容器。

# Supabase（Dashboard → Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# DeepSeek LLM
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
LLM_PROVIDER=deepseek

# embedding（自托管走本地微服务；切 DeepInfra 时配 EMBED_API_KEY/EMBED_MODEL）
EMBED_URL=http://embed-svc:8765
EMBED_API_KEY=
EMBED_MODEL=BAAI/bge-m3

# 防 undici 拦截内网调用（防御性）
NO_PROXY=localhost,127.0.0.1,embed-svc

NODE_ENV=production
